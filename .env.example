OUUI_VERSION=v0.5.0
OUUI_PANEL_PORT=3000
OUUI_DOMAIN=example.com
OUUI_ENABLE_SSL=no
OUUI_SECURE_PATH=/change-me
OUUI_ADMIN_USER=change_me
OUUI_ADMIN_PASSWORD=change_me_with_random_value
OUUI_JWT_SECRET=change_me_with_random_value
OUUI_AGENT_JOIN_TOKEN=change_me_with_random_value
OUUI_AGENT_OFFLINE_AFTER_SECONDS=45
OUUI_TASK_TIMEOUT_SECONDS=300
OUUI_DB=/app/data/ou-ui.db
OUUI_TLS_CERT_FILE=/app/certs/fullchain.pem
OUUI_TLS_KEY_FILE=/app/certs/privkey.pem
